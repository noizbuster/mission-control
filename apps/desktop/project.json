{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "desktop",
  "projectType": "application",
  "root": "apps/desktop",
  "sourceRoot": "apps/desktop/src",
  "implicitDependencies": ["config", "core", "protocol"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/desktop",
        "command": "tsc -p tsconfig.json && vite build"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/desktop",
        "command": "tsc -p tsconfig.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run apps/desktop/src --reporter verbose"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/desktop",
        "command": "vite --host 127.0.0.1",
        "forwardAllArgs": true
      }
    },
    "tauri-test": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml"
      }
    }
  }
}
