{
  "name": "@mission-control/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Mission Control CLI TUI",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "mctrl": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "sh -c 'while [ \"${1:-}\" = \"--\" ]; do shift; done; pnpm build >/dev/null && node dist/index.js \"$@\"' --",
    "test": "sh -c 'cd ../.. && while [ \"${1:-}\" = \"--\" ]; do shift; done; vitest run --reporter verbose \"$@\"' --",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mission-control/config": "workspace:*",
    "@mission-control/core": "workspace:*",
    "@mission-control/protocol": "workspace:*"
  }
}
