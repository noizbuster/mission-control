{
  "name": "mission-control",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t build",
    "dev:cli": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run cli:dev --",
    "dev:desktop": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run desktop:dev",
    "dev:package-cli": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run workspace:package-cli",
    "dev:sidecar": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run sidecar:dev --",
    "lint": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run workspace:lint",
    "smoke:coding-agent-built-dist": "node --experimental-strip-types scripts/coding-agent-built-dist-smoke.ts",
    "smoke:coding-agent-mcp-tools": "node --experimental-strip-types scripts/coding-agent-built-dist-mcp-smoke.ts",
    "test": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t test",
    "typecheck": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.0",
    "diff": "^9.0.0",
    "nx": "23.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
