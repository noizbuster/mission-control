{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "core",
  "projectType": "library",
  "root": "packages/core",
  "sourceRoot": "packages/core/src",
  "implicitDependencies": ["protocol"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "packages/core",
        "commands": [
          "node ../../scripts/generate-bundled-agents.mjs",
          "tsc -p tsconfig.json"
        ],
        "parallel": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/core",
        "command": "tsc -p tsconfig.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run packages/core/src --reporter verbose"
      }
    }
  }
}
