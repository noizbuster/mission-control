{
  "name": "@mission-control/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js"
    },
    "./redaction": {
      "types": "./dist/redaction.d.ts",
      "import": "./dist/redaction.js"
    }
  },
  "scripts": {
    "prebuild": "node ../../scripts/generate-bundled-agents.mjs",
    "build": "tsc -p tsconfig.json",
    "test": "sh -c 'cd ../.. && while [ \"${1:-}\" = \"--\" ]; do shift; done; vitest run --reporter verbose \"$@\"' --",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.73",
    "@mission-control/config": "workspace:*",
    "@mission-control/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
        "ai": "^6.0.208",
        "diff": "^9.0.0",
        "yaml": "^2.4.2",
        "zod": "^4.1.13"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.10"
  }
}
